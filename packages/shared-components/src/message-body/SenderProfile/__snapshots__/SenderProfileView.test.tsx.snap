exports[`SenderProfileView > does not render when hidden 1`] = `<div />`;

exports[`SenderProfileView > renders default sender profile 1`] = `
<div>
  <div
    class="mx_DisambiguatedProfile senderProfile"
    role="button"
    tabindex="0"
  >
