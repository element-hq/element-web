    </span>
  </div>
</div>
`;

exports[`SenderProfileView > renders disambiguated identifier 1`] = `
<div>
  <div
    class="mx_DisambiguatedProfile senderProfile"
    role="button"
    tabindex="0"
  >
    <span
      class="senderProfile_displayName"
      dir="auto"
    >
      Alice
    </span>
    <span
      class="mx_DisambiguatedProfile senderProfile_mxid"
    >
