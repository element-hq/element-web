.mx_PictureInPictureDragger {
    cursor: grab;
    user-select: none;
    left: 0;
    position: fixed;
    top: 0;
    /* Display above any widget elements */
    z-index: 102;
}

.mx_PictureInPictureDragger:active {
    cursor: grabbing;
}
