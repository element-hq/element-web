exports[`TimelineScrollPanel should handle large numbers of hidden events quickly 1`] = `
<DocumentFragment>
  <div
    class="mx_AutoHideScrollbar mx_ScrollPanel cls"
    style="display: flex; flex-direction: column; min-height: 0; position: relative;"
    tabindex="-1"
  >
    <div
      class="mx_RoomView_messageListWrapper"
      style="flex: 1 1 0%; min-height: 0;"
    >
      <div
        data-testid="virtuoso-scroller"
        data-virtuoso-scroller="true"
        style="height: 100%; outline: none; overflow-y: auto; position: relative; -webkit-overflow-scrolling: touch; flex: 1 1 0%; min-height: 0; overflow-anchor: none;"
        tabindex="0"
