.mx_SSOButtons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;

    .mx_SSOButtons_row {
        & + .mx_SSOButtons_row {
            margin-top: 16px;
        }
    }

    .mx_SSOButton {
        position: relative;
        width: 100%;
        display: inline-block;

        > img {
            object-fit: contain;
            position: absolute;
            left: 8px;
            top: 4px;
        }
    }

    .mx_SSOButton_mini {
        > img {
            left: 12px;
            top: 12px;
        }

        & + .mx_SSOButton_mini {
            margin-left: 16px;
        }
    }
}
